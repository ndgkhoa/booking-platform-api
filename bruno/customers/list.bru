meta {
  name: List customers
  type: http
  seq: 3
}

get {
  url: {{apiUrl}}/customers?page=1&limit=20
  auth: bearer
}

params:query {
  page: 1
  limit: 20
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.meta.total: isDefined
}

docs {
  Paginated customer list. Any tenant member may read. `limit` max is 100.
}
