meta {
  name: Get current user
  type: http
  seq: 1
}

get {
  url: {{apiUrl}}/users/me
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.data.email: isDefined
}

docs {
  Returns the authenticated user. Run Register or Login first to populate `token`.
  Without a token this returns 401 UNAUTHORIZED.
}
