meta {
  name: Tenant detail (super admin)
  type: http
  seq: 2
}

get {
  url: {{apiUrl}}/admin/tenants/:tenantId
  body: none
  auth: bearer
}

params:path {
  tenantId: 11db0a4d-6dca-4213-a66d-f6fd3755736d
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

docs {
  Detailed view of one tenant. Requires super-admin (log in as admin@example.com).
  Paste a tenant id into the `tenantId` path param. Unknown id returns 404 NOT_FOUND.
}
