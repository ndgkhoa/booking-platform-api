# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# PostgreSQL
# NOTE: until RLS is wired into the runtime (Phase 3), the app relies on
# application-layer tenant scoping and connects as the table owner/superuser.
# Do NOT switch DB_USER to a non-superuser role before then — FORCE RLS on
# tenant_members would block writes/reads since the request path sets no GUC.
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=booking_flow
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=15m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Observability
LOG_LEVEL=info
SWAGGER_ENABLED=true
METRICS_ENABLED=true
