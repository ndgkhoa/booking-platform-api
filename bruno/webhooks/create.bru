meta {
  name: Create webhook
  type: http
  seq: 1
}

post {
  url: {{apiUrl}}/webhooks
  body: json
  auth: bearer
}

body:json {
  {
    "url": "https://example.com/hooks/booking-events"
  }
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 201
  res.body.success: eq true
}

docs {
  Register an outbound webhook endpoint for the tenant. Requires the `owner` role.
  `url` must be https and pass SSRF safety checks (else 400). Copy the returned id
  for the Delete request.
}
