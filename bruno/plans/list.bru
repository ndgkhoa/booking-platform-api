meta {
  name: List plans
  type: http
  seq: 1
}

get {
  url: {{apiUrl}}/plans
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

docs {
  Public plan catalog, readable by any authenticated user. Copy a plan id from the
  response and paste it into Create subscription.
}
