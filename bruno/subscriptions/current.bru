meta {
  name: Get current subscription
  type: http
  seq: 2
}

get {
  url: {{apiUrl}}/subscriptions/current
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

docs {
  Fetch the tenant's active subscription. Requires any tenant member. Returns null
  data when the tenant has never subscribed.
}
