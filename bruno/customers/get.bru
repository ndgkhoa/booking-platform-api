meta {
  name: Get customer by id
  type: http
  seq: 2
}

get {
  url: {{apiUrl}}/customers/:customerId
  body: none
  auth: bearer
}

params:path {
  customerId: ec04a761-2fc8-4a7f-91c1-513dbfadc8a2
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
}

docs {
  Fetch a customer by id. Paste a customer id into the `customerId` path param.
  Any tenant member may read. Unknown id returns 404 NOT_FOUND.
}
