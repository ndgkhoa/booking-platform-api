meta {
  name: Health (readiness)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/health/ready
  auth: none
}

assert {
  res.status: eq 200
}

docs {
  Terminus readiness check — verifies Postgres + Redis are reachable. Returns 503
  if a dependency is down. `/health/live` is the dependency-free liveness probe.
  Note: these are at the root (not under /api).
}
