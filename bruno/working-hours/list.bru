meta {
  name: List working hours
  type: http
  seq: 3
}

get {
  url: {{apiUrl}}/staff/:staffId/working-hours
  body: none
  auth: bearer
}

params:path {
  staffId: 6b47117a-7902-465f-8aca-c7f539896d1e
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
}

docs {
  List a staff member's weekly working hours. `staffId` is the staff member to
  read. Unknown id returns 404 NOT_FOUND.
}
