# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
INVITE_TTL_DAYS=7
APP_URL=http://localhost:3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Observability
LOG_LEVEL=info
SWAGGER_ENABLED=true
METRICS_ENABLED=true

# Tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=booking-platform-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
