meta {
  name: Get user by id
  type: http
  seq: 3
}

get {
  url: {{apiUrl}}/users/:userId
  auth: bearer
}

params:path {
  userId: 7433a163-6161-42ff-b708-8e271f27543e
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
}

docs {
  Fetch a user by id. Paste a real user id into the `userId` path param. Unknown
  id returns 404 NOT_FOUND.
}
