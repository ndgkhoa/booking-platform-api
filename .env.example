# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=booking_flow
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=15m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Observability
LOG_LEVEL=info
SWAGGER_ENABLED=true
METRICS_ENABLED=true
